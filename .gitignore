# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ONNX Runtime WASM binaries
public/ort-wasm-*
public/models/

# Next.js broken/duplicate caches
.next-broken-dev-*
.next-dev*.log
.next-dev*.pid
.next-dev*.port
/.next */

# Claude Code
.claude/
server/.env
server/node_modules/
server/dist/
